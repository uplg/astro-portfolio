---
import '../styles/theme.css';
import PerlinFlowBackground from '../components/background/PerlinFlowBackground';
import Footer from '../components/Footer';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname === "/" ? "/" : Astro.url.pathname.replace(/\/$/, "");
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://status.uplg.xyz">
    <link rel="preconnect" href="https://plausible.uplg.xyz">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter fallback="swap" />
    <script defer is:inline data-domain="uplg.xyz" src="https://plausible.uplg.xyz/js/script.js"></script>
  </head>
  <body class="no-js">
    <script is:inline>
      document.body.classList.remove('no-js');
      
      document.addEventListener('astro:page-load', () => {
        document.body.classList.remove('no-js');
      });

      (() => {
        const resolveTheme = () => {
          try {
            const saved = localStorage.getItem('theme');
            if (saved === 'dark' || saved === 'light') return saved;
          } catch {}
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };

        document.documentElement.setAttribute('data-theme', resolveTheme());

        document.addEventListener('astro:before-swap', (e) => {
          const theme = document.documentElement.getAttribute('data-theme') || resolveTheme();
          e.newDocument.documentElement.setAttribute('data-theme', theme);
        });
      })();
    </script>
    <PerlinFlowBackground client:load transition:persist />
    <slot />
    <Footer client:load transition:persist currentPath={currentPath} />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Kotori Rose';
    src: url('/kotori-regular-webfont.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --uplg-background-color: #f2f2f2;
    --uplg-font-color: #2f2f2f;
    --uplg-font-hover: rgb(0, 0, 0, 0.3);
    --uplg-primary: #525252;
    --uplg-font-primary: "Kotori Rose", -apple-system, BlinkMacSystemFont,
      "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  html,
  body {
    width: 100%;
    height: 100vh;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
  }

  html {
    background-color: var(--app-container);
  }

  body {
    max-width: 1920px;
    min-height: 100vh;
    padding: 2rem;
    padding-bottom: 5rem;
    color: var(--main-color);
    font-family: var(--uplg-font-primary);
    justify-content: center;
    background: transparent;
    position: relative;
  }

  a {
    text-decoration: none;
    color: var(--main-color);
    opacity: 0.8;
    transition: opacity 0.3s;
    position: relative;
  }

  a:hover {
    opacity: 1;
  }

  .contact a,
  .hero a {
    display: inline-flex;
    align-items: center;
    position: relative;
  }

  h1 {
    font-size: 1.5em;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  h1,
  h2,
  h3,
  h4 {
    user-select: none;
    color: var(--main-color);
  }

  h2 {
    font-size: 1.3em;
    letter-spacing: -0.01em;
    opacity: 0.95;
  }

  p {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  button,
  a {
    cursor: pointer;
  }

  .flex-link {
    display: flex;
    flex-direction: row;
    align-items: center;
  }

  .justify-center {
    justify-content: center;
  }

  .justify-end {
    justify-content: flex-end;
  }

  .app-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: 0.2s;
  }

  .app-container button,
  .app-container input,
  .app-container optgroup,
  .app-container select,
  .app-container textarea {
    font-family: var(--uplg-font-primary);
  }

  .page {
    margin-top: 0px;
    margin-right: auto;
    margin-bottom: 50px;
    margin-left: auto;
    padding: 20px;
  }

  .hero {
    margin-bottom: 48px;
    border-radius: 12px;
  }

  .hero h1 {
    margin-bottom: 100px;
  }

  .status .hero h1 {
    margin-bottom: 0;
  }

  .contact .hero h1 {
    margin-bottom: 0;
  }

  .areas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }

  .service {
    user-select: none;
    border-radius: 12px;
  }

  .service h2 {
    margin: 10px 0;
  }

  .service ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .service li {
    padding: 0.25rem 0;
    color: var(--text-secondary);
  }

  .service li:before {
    content: "\2192";
    margin-right: 0.5rem;
    opacity: 0.5;
  }

  .service a {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 48px;
    margin-right: 40px;
  }

  .links {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 26px;
    user-select: none;
  }

  .links span {
    cursor: pointer;
  }

  .projects {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 36px;
    padding: 10px;
    margin: 2rem 0;
  }

  .project {
    display: flex;
    padding: 28px 16px;
    background: var(--surface);
    flex-direction: column;
    align-items: flex-start;
    border-radius: 15px;
    border: 1px solid var(--surface-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .project:hover {
    background: var(--surface-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--accent-glow);
    border-color: rgba(160, 120, 255, 0.15);
  }

  .project > a {
    font-size: 1.2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .project .excerpt {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .project .excerpt p:first-child {
    font-size: 0.9em;
    margin: 0.5rem 0;
    color: var(--text-secondary);
  }

  .project .excerpt .extra {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .project .excerpt .extra svg {
    height: 30px;
  }

  .tags {
    display: flex;
    flex-direction: row;
    gap: 5px;
    font-size: 0.8em;
    margin: 1rem 0;
  }

  .tag {
    background: var(--surface);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    font-size: 0.75em;
    opacity: 0.85;
    cursor: default;
    border: 1px solid var(--surface-border);
    letter-spacing: 0.02em;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .project:hover .tag {
    border-color: rgba(160, 120, 255, 0.12);
  }

  .state {
    background: var(--surface);
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    font-size: 0.75rem;
    border: 1px solid var(--surface-border);
    color: var(--text-muted);
  }

  .extra {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
  }

  .extra a {
    width: 20px;
    height: 20px;
    opacity: 0.7;
  }

  .extra a:hover {
    opacity: 1;
  }

  .repo-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .repo-info a {
    display: flex;
    align-items: center;
    width: auto;
    height: auto;
  }

  .repo-info svg {
    height: 20px;
    width: 20px;
  }

  .stars-count {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.8rem;
    opacity: 0.9;
  }

  .stars-count svg {
    width: 12px;
    height: 12px;
    color: #f0c14b;
  }

  .header {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    z-index: 10;
    background: transparent;
  }

  .contact .methods {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-intro {
    font-size: 1.05rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 40vw;
  }

  .contact-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border: 1px solid var(--surface-border);
    border-radius: 10px;
    background: var(--surface);
    transition: background-color 0.2s ease, border-color 0.2s ease;
    opacity: 1;
    text-decoration: none;
  }

  .contact-card:hover {
    background: var(--surface-hover);
    border-color: var(--surface-hover);
    opacity: 1;
  }

  .contact-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  .contact-value {
    font-size: 0.95rem;
    color: var(--main-color);
    opacity: 0.8;
  }

  .contact-card:hover .contact-value {
    opacity: 1;
  }

  .status-overview {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 10px;
    background: var(--surface);
    border: 1px solid;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    margin-bottom: 2rem;
  }

  .status-overview-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  .status-overview-text {
    font-size: 1rem;
    color: var(--main-color);
  }

  .status-error {
    color: #ef4444;
    font-size: 0.9rem;
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .status-card {
    padding: 1rem 1.25rem;
    border-radius: 10px;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .status-card:hover {
    background: var(--surface-hover);
  }

  .status-card-loading {
    min-height: 72px;
  }

  .status-card-name-placeholder,
  .status-card-meta-placeholder {
    height: 14px;
    border-radius: 4px;
    background: var(--surface-hover);
  }

  .status-card-name-placeholder {
    width: 60%;
    margin-bottom: 0.75rem;
  }

  .status-card-meta-placeholder {
    width: 40%;
  }

  .status-card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .status-card-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-card-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--main-color);
  }

  .status-card-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .status-card-ping {
    font-variant-numeric: tabular-nums;
  }

  .status-card-uptime {
    font-variant-numeric: tabular-nums;
  }

  .status-card-uptime-label {
    opacity: 0.6;
    font-size: 0.7rem;
  }

  .status-footer-note {
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media screen and (max-width: 450px) {
    .status-grid {
      grid-template-columns: 1fr;
    }
  }

  @media only screen and (min-width: 840px) {
    .service {
      margin-bottom: 100px;
    }
  }

  @media only screen and (max-width: 840px) {
    body {
      padding: 1.5rem;
    }
  }

  @media screen and (max-width: 520px) {
    .areas {
      gap: 50px;
    }
  }

  @media screen and (max-width: 450px) {
    .areas {
      display: inline-block;
    }

    .projects {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    }

    .project .excerpt .extra {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .project .excerpt .tags {
      flex-direction: column;
    }

    .repo-info {
      margin-top: 0.25rem;
    }
  }

  .footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 2rem;
    background: var(--surface);
    border-top: 1px solid var(--surface-border);
    z-index: 100;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    z-index: -1;
  }

  .footer-content {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-link {
    color: var(--main-color);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.3s ease;
    font-size: 0.9rem;
  }

  .footer-link:hover {
    opacity: 1;
  }

  .footer-link.active {
    opacity: 1;
    font-weight: 600;
    color: var(--main-color);
  }

  .footer-link > svg {
    width: 35px;
    height: 35px;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background-color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-link > svg:hover {
    background-color: var(--surface-hover);
  }

  .footer-controls {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer-btn {
    background: none;
    border: 1px solid var(--surface-border);
    color: var(--main-color);
    font-family: var(--uplg-font-primary);
    font-size: 0.8rem;
    cursor: pointer;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    opacity: 0.8;
    line-height: 1;
    user-select: none;
  }

  .footer-btn:hover {
    opacity: 1;
    background-color: var(--surface-hover);
  }

  .footer-btn-debug {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0.78;
  }

  .footer-btn-debug:hover {
    opacity: 1;
  }

  .no-js .footer-btn {
    display: none;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--main-color);
  }

  .status-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .status-text {
    font-size: 0.85rem;
    opacity: 0.9;
  }

  @keyframes pulse {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 currentColor;
    }
    
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 4px transparent;
    }
    
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-pulse {
      animation: none;
    }
  }

  .burger-toggle {
    display: none;
  }

  .burger-menu {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    transition: background-color 0.2s ease;
    position: relative;
    z-index: 103;
  }

  .burger-menu:hover {
    background-color: var(--surface-hover);
  }

  .burger-label {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    transition: background-color 0.2s ease;
    position: relative;
    z-index: 103;
  }

  .burger-label:hover {
    background-color: var(--surface-hover);
  }

  .burger-line {
    width: 20px;
    height: 2px;
    background-color: var(--main-color);
    margin: 2px 0;
    transition: 0.3s;
    border-radius: 1px;
  }

  .burger-line.open:nth-child(1) {
    transform: rotate(-45deg) translate(-4px, 4px);
  }

  .burger-line.open:nth-child(2) {
    opacity: 0;
  }

  .burger-line.open:nth-child(3) {
    transform: rotate(45deg) translate(-4px, -4px);
  }

  .burger-toggle:checked ~ .footer .burger-label .burger-line:nth-child(1) {
    transform: rotate(-45deg) translate(-4px, 4px);
  }

  .burger-toggle:checked ~ .footer .burger-label .burger-line:nth-child(2) {
    opacity: 0;
  }

  .burger-toggle:checked ~ .footer .burger-label .burger-line:nth-child(3) {
    transform: rotate(45deg) translate(-4px, -4px);
  }

  .burger-toggle:checked ~ .footer .footer-menu {
    transform: translateY(0);
  }

  .footer-menu {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--surface);
    border-top: 1px solid var(--surface-border);
    transform: translateY(100%);
    transition: transform 0.3s ease;
    z-index: 102;
    display: none;
  }

  .footer-menu::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: -1;
  }

  .footer-menu.open {
    transform: translateY(0);
  }

  .footer-menu-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 1rem;
    max-width: 300px;
    margin: 0 auto;
  }

  .footer-menu .footer-link {
    font-size: 1.1rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    transition: background-color 0.2s ease;
    width: 100%;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-menu .footer-link:hover {
    background-color: var(--surface-hover);
  }

  .footer-menu .footer-link.active {
    background-color: var(--surface);
    font-weight: 600;
  }

  .footer-menu .footer-link > svg {
    width: 24px;
    height: 24px;
    padding: 0;
  }

  .footer-menu .footer-controls {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  .footer-menu .footer-btn {
    font-size: 0.9rem;
    padding: 0.5rem 1rem;
  }

  .no-js .status-indicator {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .burger-menu {
      display: flex;
    }

    .no-js .burger-menu {
      display: none;
    }

    .no-js .burger-label {
      display: flex;
    }

    .footer-menu {
      display: block;
    }

    .desktop-menu {
      display: none;
    }

    .footer {
      padding: 0.75rem 1rem;
      justify-content: center;
    }

    .areas {
      margin-bottom: 3rem;
    }
  }

  @media screen and (min-width: 769px) {
    .burger-menu {
      display: none;
    }

    .footer-menu {
      display: none;
    }

    .desktop-menu {
      display: flex;
    }
  }

  @media screen and (max-width: 450px) {
    .footer {
      padding: 0.75rem 1rem;
    }

    .footer-content {
      gap: 1rem;
    }

    .footer-link {
      font-size: 0.8rem;
    }

    .status-indicator {
      gap: 0.3rem;
    }

    .status-text {
      font-size: 0.75rem;
    }

    .footer-menu-content {
      gap: 1.2rem;
      padding: 1.5rem 1rem;
    }

    .footer-menu .footer-link {
      font-size: 1rem;
    }

  }
</style>